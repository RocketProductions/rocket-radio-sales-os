// Rocket Radio Sales OS — Prisma Schema
// Connects to existing Supabase project: rocket-content-os
// Existing tables (tenants, app_users, brands, etc.) are mapped as-is.
// New tables (campaigns, campaign_steps, leads, lead_events, automation_runs) are added for the 4-Part Revenue System.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── EXISTING TABLES (from Supabase rocket-content-os) ───

model Tenant {
  id                   String   @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  name                 String
  slug                 String   @unique
  planTier             String   @default("starter") @map("plan_tier")
  postsUsedThisMonth   Int      @default(0) @map("posts_used_this_month")
  billingCycleStart    DateTime @default(now()) @map("billing_cycle_start") @db.Timestamptz
  whiteLabelDomain     String?  @map("white_label_domain")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz
  wlBrandName          String?  @map("wl_brand_name")
  wlLogoUrl            String?  @map("wl_logo_url")
  wlPrimaryColor       String?  @default("#6366f1") @map("wl_primary_color")
  wlCustomDomain       String?  @map("wl_custom_domain")
  wlSupportEmail       String?  @map("wl_support_email")
  wlHideRocketBranding Boolean? @default(false) @map("wl_hide_rocket_branding")
  ownerId              String?  @map("owner_id") @db.Uuid

  users        AppUser[]
  brands       Brand[]
  assets       Asset[]
  subscription Subscription?
  usageLogs    UsageLog[]

  @@map("tenants")
}

model AppUser {
  id          String   @id @db.Uuid
  tenantId    String?  @map("tenant_id") @db.Uuid
  email       String
  name        String   @default("")
  role        String   @default("client_owner")
  brandAccess String[] @default([]) @map("brand_access") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  isSuperAdmin Boolean? @default(false) @map("is_super_admin")

  tenant Tenant? @relation(fields: [tenantId], references: [id])
  posts  Post[]

  @@map("app_users")
}

model Brand {
  id              String   @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  tenantId        String?  @map("tenant_id") @db.Uuid
  name            String
  industry        String?  @default("")
  websiteUrl      String?  @map("website_url")
  logoUrl         String?  @map("logo_url")
  primaryColor    String?  @default("#1A1A2E") @map("primary_color")
  secondaryColor  String?  @default("#16213E") @map("secondary_color")
  accentColor     String   @default("#E94560") @map("accent_color")
  backgroundColor String?  @default("#F5F0E8") @map("background_color")
  fontHeadline    String?  @default("Playfair Display") @map("font_headline")
  fontBody        String?  @default("Inter") @map("font_body")
  toneWords       String[] @default([]) @map("tone_words")
  bannedWords     String[] @default([]) @map("banned_words")
  styleRules      String[] @default([]) @map("style_rules")
  contentPillars  String[] @default([]) @map("content_pillars")
  sampleCopy      String[] @default([]) @map("sample_copy")
  primaryPlatform String?  @default("instagram") @map("primary_platform")
  igHandle        String?  @map("ig_handle")
  fbPageId        String?  @map("fb_page_id")
  linkedinUrl     String?  @map("linkedin_url")
  tiktokHandle    String?  @map("tiktok_handle")
  complianceFlags String[] @default([]) @map("compliance_flags")
  createdAt       DateTime? @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime? @default(now()) @map("updated_at") @db.Timestamptz
  workflowMode    String?  @default("agency_generates") @map("workflow_mode")
  agencyId        String?  @map("agency_id") @db.Uuid
  description     String?
  tagline         String?
  targetAudience  String?  @map("target_audience")
  tone            String[]

  tenant          Tenant?          @relation(fields: [tenantId], references: [id])
  posts           Post[]
  assets          Asset[]
  workflowConfig  WorkflowConfig?
  socialConnections SocialConnection[]
  campaigns       Campaign[]

  @@map("brands")
}

model Post {
  id              String    @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  brandId         String    @map("brand_id") @db.Uuid
  createdByUserId String?   @map("created_by_user_id") @db.Uuid
  contentType     String    @map("content_type")
  status          String    @default("draft")
  brief           Json      @default("{}")
  generatedCopy   Json?     @map("generated_copy")
  renderedImages  String[]  @default([]) @map("rendered_images")
  platformSpecs   String[]  @default([]) @map("platform_specs")
  approvalNotes   String?   @map("approval_notes")
  publishedAt     DateTime? @map("published_at") @db.Timestamptz
  publishedTo     String[]  @default([]) @map("published_to")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @default(now()) @map("updated_at") @db.Timestamptz
  reviewedBy      String?   @map("reviewed_by") @db.Uuid
  reviewedAt      DateTime? @map("reviewed_at") @db.Timestamptz
  publishedUrl    String?   @map("published_url")

  brand     Brand    @relation(fields: [brandId], references: [id])
  createdBy AppUser? @relation(fields: [createdByUserId], references: [id])

  @@map("posts")
}

model Asset {
  id          String   @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  brandId     String?  @map("brand_id") @db.Uuid
  type        String   @default("photo")
  storagePath String   @map("storage_path")
  publicUrl   String   @map("public_url")
  filename    String
  tags        String[] @default([])
  width       Int?
  height      Int?
  fileSize    Int      @default(0) @map("file_size")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])
  brand  Brand? @relation(fields: [brandId], references: [id])

  @@map("assets")
}

model Subscription {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId             String    @unique @map("tenant_id") @db.Uuid
  plan                 String    @default("starter")
  status               String    @default("trialing")
  stripeCustomerId     String?   @map("stripe_customer_id")
  stripeSubscriptionId String?   @map("stripe_subscription_id")
  currentPeriodEnd     DateTime? @map("current_period_end") @db.Timestamptz
  cancelAtPeriodEnd    Boolean?  @default(false) @map("cancel_at_period_end")
  createdAt            DateTime? @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime? @default(now()) @map("updated_at") @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("subscriptions")
}

model WorkflowConfig {
  id                           String   @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  brandId                      String   @unique @map("brand_id") @db.Uuid
  mode                         String   @default("agency_generates")
  requireApprovalBeforeDownload Boolean @default(false) @map("require_approval_before_download")
  autoApproveAfterHours        Int?     @map("auto_approve_after_hours")
  notifyOnDraft                String[] @default([]) @map("notify_on_draft")
  notifyOnApproval             String[] @default([]) @map("notify_on_approval")

  brand Brand @relation(fields: [brandId], references: [id])

  @@map("workflow_configs")
}

model SocialConnection {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  brandId      String    @map("brand_id") @db.Uuid
  platform     String
  accessToken  String    @map("access_token")
  refreshToken String?   @map("refresh_token")
  expiresAt    DateTime? @map("expires_at") @db.Timestamptz
  accountName  String?   @map("account_name")
  accountId    String?   @map("account_id")
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamptz

  brand Brand @relation(fields: [brandId], references: [id])

  @@map("social_connections")
}

model UsageLog {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  month          String
  postsGenerated Int?      @default(0) @map("posts_generated")
  imagesRendered Int?      @default(0) @map("images_rendered")
  updatedAt      DateTime? @default(now()) @map("updated_at") @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("usage_logs")
}

// ─── NEW TABLES: 4-Part Revenue System ───

/// A campaign for a client (brand). Created by a sales rep.
/// Maps to the 17-step campaign framework.
model Campaign {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  brandId     String   @map("brand_id") @db.Uuid
  createdBy   String   @map("created_by") @db.Uuid
  name        String
  tier        String   @default("starter") // starter | growth | scale
  status      String   @default("draft")   // draft | active | paused | completed
  bigIdea     String?  @map("big_idea")
  offerText   String?  @map("offer_text")
  goalType    String?  @map("goal_type")   // leads | traffic | awareness | hiring
  audience    String?
  seasonality String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamptz

  brand Brand          @relation(fields: [brandId], references: [id])
  steps CampaignStep[]
  leads Lead[]

  @@map("campaigns")
}

/// Individual step output within a campaign (maps to the 17-step framework).
/// Each step stores AI-generated output and completion status.
model CampaignStep {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaignId String   @map("campaign_id") @db.Uuid
  stepNumber Int      @map("step_number")  // 1-17
  stepType   String   @map("step_type")    // client-intake, radio-script, funnel-copy, etc.
  status     String   @default("pending")  // pending | generating | completed | skipped
  aiOutput   Json?    @map("ai_output")    // Structured AI output for this step
  humanEdits Json?    @map("human_edits")  // Any manual edits by the rep
  completedAt DateTime? @map("completed_at") @db.Timestamptz
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, stepNumber])
  @@map("campaign_steps")
}

/// A lead captured from a campaign (form submission, Meta Lead Ad, manual entry).
model Lead {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaignId String   @map("campaign_id") @db.Uuid
  firstName  String?  @map("first_name")
  lastName   String?  @map("last_name")
  email      String?
  phone      String?
  source     String   @default("manual")   // manual | meta_lead_ad | form | second_street
  status     String   @default("new")      // new | contacted | booked | closed | lost
  notes      String?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @default(now()) @map("updated_at") @db.Timestamptz

  campaign Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  events   LeadEvent[]

  @@map("leads")
}

/// Timeline events for a lead. Every action gets logged here.
/// Powers the activity feed: "We texted Sarah at 2:03pm"
model LeadEvent {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  leadId    String   @map("lead_id") @db.Uuid
  eventType String   @map("event_type")  // auto_text | auto_email | manual_call | status_change | booked | closed
  message   String?                       // Human-readable: "We texted them instantly"
  metadata  Json?                          // Extra data (phone number, email subject, etc.)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("lead_events")
}

/// Tracks automated follow-up runs per lead.
/// Each run = one execution of an automation sequence step.
model AutomationRun {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  leadId       String    @map("lead_id") @db.Uuid
  sequenceStep Int       @map("sequence_step")  // 1 = instant, 2 = day 1, 3 = day 3, etc.
  actionType   String    @map("action_type")     // text | email | reminder
  status       String    @default("pending")     // pending | sent | failed | skipped
  scheduledFor DateTime  @map("scheduled_for") @db.Timestamptz
  executedAt   DateTime? @map("executed_at") @db.Timestamptz
  errorMessage String?   @map("error_message")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@map("automation_runs")
}

// ─── INTEGRATION TABLES ───

/// Stores credentials and config for external integrations (email, SMS, calendar, etc.)
/// One row per integration type per tenant. Credentials are stored encrypted.
model IntegrationConfig {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  provider     String    // email | sms | calendar | apollo | stripe | canva | wix
  enabled      Boolean   @default(false)
  credentials  Json      @default("{}") // Encrypted: apiKey, accountSid, etc.
  settings     Json      @default("{}") // Non-secret config: fromEmail, fromPhone, etc.
  lastVerified DateTime? @map("last_verified") @db.Timestamptz
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @default(now()) @map("updated_at") @db.Timestamptz

  @@unique([tenantId, provider])
  @@map("integration_configs")
}

/// Audit log for every integration call. Keeps a record of what was sent to whom.
model IntegrationLog {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  provider     String   // email | sms | calendar | apollo | stripe
  action       String   // send_email | send_sms | create_event | enrich_contact | etc.
  referenceId  String?  @map("reference_id") // leadId, campaignId, etc.
  referenceType String? @map("reference_type") // lead | campaign | client
  status       String   @default("success")  // success | failed | skipped
  request      Json?    // Sanitized request payload (no credentials)
  response     Json?    // Sanitized response
  errorMessage String?  @map("error_message")
  durationMs   Int?     @map("duration_ms")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("integration_logs")
}
